rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAllowed() {
      return isSignedIn() && exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email));
    }

    // Comic Info Validation
    function isValidComic(data) {
      return data.title is string && data.title.size() <= 2000
        && (data.has('userId') ? data.userId == request.auth.uid : true)
        && (data.has('timestamp') ? data.timestamp == request.time : true);
    }

    // Previous isCompleteComic was too strict, removed it from flow.

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'timestamp', 'read'])
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.type in ['status_change', 'info']
        && data.read is bool
        && (request.method == 'create' ? data.timestamp == request.time : true);
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['userId', 'userName', 'userEmail', 'message', 'timestamp'])
        && data.userId == request.auth.uid
        && data.userEmail == request.auth.token.email
        && data.userName is string && data.userName.size() <= 200
        && data.message is string && data.message.size() <= 2000
        && data.timestamp == request.time;
    }

    // Whitelist access
    match /allowedUsers/{email} {
      allow read: if isSignedIn() && request.auth.token.email == email;
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(notificationId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() 
        && isValidId(notificationId)
        && isOwner(existing().userId) 
        && incoming().read == true 
        && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && isValidId(notificationId) && isOwner(existing().userId);
    }

    // Chat Collection
    match /chat_messages/{messageId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(messageId);
      allow create: if isSignedIn() && isValidChatMessage(incoming());
      allow delete: if false; 
      allow update: if false; 
    }

    // Recent Reads Collection
    match /recent_reads/{readId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }
  }
}
